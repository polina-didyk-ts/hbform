# Database
# For Docker Compose PostgreSQL (recommended for local development)
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/ts_web_starter_dev?schema=public"
# Or use your own PostgreSQL instance:
# DATABASE_URL="postgresql://user:password@localhost:5432/dbname?schema=public"

# Better Auth
BETTER_AUTH_SECRET="your-secret-key-change-in-production"
NEXT_PUBLIC_BETTER_AUTH_URL="http://localhost:3000"

# Google OAuth
# Get credentials from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Google Sheets sync (gift form) — service account, NOT the OAuth client above.
# Setup steps: docs/google-sheets-setup.md
GOOGLE_SHEETS_CLIENT_EMAIL=
GOOGLE_SHEETS_PRIVATE_KEY=
GOOGLE_SHEETS_SPREADSHEET_ID=

# App
NODE_ENV="development"
AWS_REGION="eu-central-1"

# CORS Configuration (optional)
# Allowed origin for API access from mobile apps or other domains
# Set to "*" to allow all origins (development only) or specify your app's domain
# ALLOWED_ORIGIN="https://yourdomain.com"
# For development with Expo/React Native: ALLOWED_ORIGIN="*"

# Sentry (optional)
# Get DSN from: https://sentry.io/settings/<org>/projects/<project>/keys/
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENVIRONMENT="development"
# Auth token for source map uploads (CI only)
# SENTRY_AUTH_TOKEN=
