# E2E Test Environment Configuration
# This file is used during Playwright test execution

# Database - Uses existing Docker Compose PostgreSQL with public schema
# All workers share the same schema, test isolation via unique users
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/ts_web_starter_dev?schema=public"

# Better Auth Configuration
BETTER_AUTH_SECRET="test-secret-key-for-e2e-testing-do-not-use-in-production"
NEXT_PUBLIC_BETTER_AUTH_URL="http://localhost:3000"

# App Configuration
NODE_ENV="test"
AWS_REGION="eu-central-1"

# Note: OAuth credentials not needed for E2E tests (testing email/password only)
